NODE_ENV=production
PORT=8080

DATABASE_URL=postgresql://app_user:app_pass@127.0.0.1:5432/minutka
DATABASE_POOL_MAX=30
DATABASE_POOL_MIN=5
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECT_TIMEOUT_MS=5000
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_QUERY_TIMEOUT_MS=15000
DATABASE_SSL=false

JWT_ACCESS_SECRET=change_me_long_random_string
JWT_ACCESS_TTL=15m

REDIS_URL=redis://127.0.0.1:6379
CORS_ORIGIN=https://myapp.uz,https://www.myapp.uz
BODY_LIMIT=256kb
LOG_LEVEL=info

# Optional queue tuning
OUTBOX_BATCH_SIZE=100
